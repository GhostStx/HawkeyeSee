# ── HawkEye — Configuration ─────────────────────────────────────────────────
# Copiez ce fichier en .env et modifiez les valeurs :
#   cp .env.example .env

# --- Notifications Telegram ---
# Obtenez un token via @BotFather sur Telegram
HAWKEYE_TELEGRAM_TOKEN=
# ID du chat/canal (ex: -1001234567890)
HAWKEYE_TELEGRAM_CHAT_ID=

# --- Dashboard ---
HAWKEYE_DASHBOARD_HOST=127.0.0.1
HAWKEYE_DASHBOARD_PORT=5000

# --- Détection ---
# Seuil d'alerte DGA (score 0.0-1.0, défaut: 0.6)
HAWKEYE_DGA_THRESHOLD=0.6
# Fenêtre glissante DGA en secondes (défaut: 10)
HAWKEYE_DGA_WINDOW=10
# Nombre min de requêtes pour déclencher une alerte rafale (défaut: 5)
HAWKEYE_DGA_BURST=5
